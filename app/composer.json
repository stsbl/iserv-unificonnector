{
  "name": "iserv/unificonnector",
  "description": "IServ UniFi Connector",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-ctype": "*",
    "ext-gettext": "*",
    "ext-iconv": "*",
    "ext-intl": "*",
    "ext-mbstring": "*",
    "art-of-wifi/unifi-api-client": "^1.1",
    "doctrine/doctrine-bundle": "^2.13",
    "doctrine/orm": "^2.20",
    "iserv/admin-integration-bundle": "^1.0",
    "iserv/appkernel": "^1.4",
    "iserv/authentication-bundle": "^2.10",
    "iserv/autocomplete-bundle": "^1.9",
    "iserv/doctrine-bundle": "^1.3",
    "iserv/error-bundle": "^1.0",
    "iserv/form-bundle": "^1.12",
    "iserv/idm-api-client": "^1.0",
    "iserv/idm-data-broker-bundle": "^0.6",
    "iserv/module-bundle": "^1.11",
    "iserv/module-response": "^2.5",
    "iserv/module-response-symfony-bridge": "^1.3",
    "iserv/translation-gettext-bundle": "^1.15",
    "nyholm/psr7": "^1.8",
    "symfony/asset": "^6.4",
    "symfony/console": "^6.4",
    "symfony/dotenv": "^6.4",
    "symfony/flex": "^2.5",
    "symfony/form": "^6.4",
    "symfony/framework-bundle": "^6.4",
    "symfony/monolog-bundle": "^3.10",
    "symfony/process": "^6.4",
    "symfony/psr-http-message-bridge": "^6.4",
    "symfony/runtime": "^6.4",
    "symfony/security-bundle": "^6.4",
    "symfony/twig-bundle": "^6.4",
    "symfony/yaml": "^6.4"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "iserv/testbrowser-bundle": "^1.1",
    "symfony/browser-kit": "^6.4",
    "symfony/debug-bundle": "^6.4",
    "symfony/stopwatch": "^6.4",
    "symfony/var-dumper": "^6.4",
    "symfony/web-profiler-bundle": "^6.4"
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-intl-grapheme": "*",
    "symfony/polyfill-intl-icu": "*",
    "symfony/polyfill-intl-idn": "1.38.1",
    "symfony/polyfill-intl-messageformatter": "*",
    "symfony/polyfill-intl-normalizer": "*",
    "symfony/polyfill-mbstring": "*",
    "symfony/polyfill-php56": "*",
    "symfony/polyfill-php70": "*",
    "symfony/polyfill-php71": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*"
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.iserv.eu"
    },
    {
      "packagist": false
    }
  ],
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "IServ\\UnifiConnector\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IServ\\UnifiConnector\\Tests\\Common\\": "tests/Common",
      "IServ\\UnifiConnector\\Tests\\Unit\\": "tests/Unit",
      "IServ\\UnifiConnector\\Tests\\Integration\\": "tests/Integration",
      "IServ\\UnifiConnector\\Tests\\Functional\\": "tests/Functional"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2.28"
    },
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  },
  "extra": {
    "cotor": {
      "extensions": {
        "phpstan/phpstan": {
          "phpstan/extension-installer": "^1.2",
          "phpstan/phpstan-doctrine": "^1.3",
          "phpstan/phpstan-symfony": "^1.2"
        },
        "vimeo/psalm": {
          "psalm/plugin-symfony": "^5.0",
          "weirdan/doctrine-psalm-plugin": "^2.10"
        }
      },
      "friendsofphp/php-cs-fixer": "^3.14",
      "phpstan/phpstan": "^1.9",
      "phpunit/phpunit": "^13.2",
      "vimeo/psalm": "^6.16"
    },
    "symfony": {
      "allow-contrib": false,
      "require": "^6.4",
      "endpoint": [
        "https://git.iserv.eu/api/v4/projects/3736/repository/files/index.json/raw?ref=master",
        "flex://defaults"
      ]
    }
  },
  "scripts": {
    "post-install-cmd": [],
    "post-update-cmd": [],
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    }
  }
}
